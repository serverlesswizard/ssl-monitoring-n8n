        "jsCode": "const stdout = $json.stdout || '';\nconst exitCode = $json.exitCode;\n\n// Certbot prints 'Congratulations' on success\nconst success = exitCode === 0 && stdout.includes('Congratulations');\n\nreturn {\n  domain: $('Init Retry State').item.json.domain,\n  port: $('Init Retry State').item.json.port,\n  expiryDate: $('Init Retry State').item.json.expiryDate,\n  daysLeft: $('Init Retry State').item.json.daysLeft,\n  retryCount: $('Init Retry State').item.json.retryCount,\n  maxRetries: $('Init Retry State').item.json.maxRetries,\n  renewalSuccess: success,\n  certbotOutput: stdout\n};\n"
      },
